# Modèle de variables d'environnement du backend BiblioTalk.
# Copie en .env pour le dev local, ou renseigne ces clés dans le dashboard Render en prod.

# Fournisseur LLM : "ollama" (local/dev) ou "gemini" (production)
LLM_PROVIDER=ollama

# Clé Google Gemini (https://aistudio.google.com/apikey) — requise si LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Origines autorisées (CORS), séparées par des virgules
CORS_ORIGINS=http://localhost:3000

# Secret de signature des tokens JWT (mets une longue chaîne aléatoire en prod)
JWT_SECRET=change-me

# Compte administrateur pré-créé au démarrage
ADMIN_EMAIL=roni.cairo@outlook.fr
ADMIN_HASH=$2y$10$...

# Limite de documents par utilisateur
MAX_FILES_PER_USER=10
